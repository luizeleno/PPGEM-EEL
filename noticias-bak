<!-- Start News -->
<div id="gallery" class="gallery">
    <div id="team" class="team">
    <h2 class="section-title">{% t secoes.noticias %}</h2>
    {% assign novas=site.noticias | reverse  %}
    {% for noticia in novas limit:4 %}
        <a href="{{ site.baseurl }}/{{ noticia.url }}" class="gallery-item expandable-box ">
            <div class="expandable-box-top">
                <img src="{{ site.baseurl_root }}/img/noticias/{{ noticia.img }}" alt="{{ noticia.titulo_br }}">
            </div>
            <div class="expandable-box-bottom">
                <span><svg class="icon icon-chain"><use xlink:href="#icon-chain"></use></svg></span>
                <span>{{noticia.titulo_br}}</span>
            </div>
        </a>
    {% endfor %}
</div>
<a class="btn btn-primary btn-lg btn-block" href="" role="button">{% t global.maisnoticias %}</a>
</div>
<!-- End News -->